# Copy this to ~/.env and fill in values after authenticating tools.
# ~/.env is sourced by .zshenv for every shell.

# GitHub usernames used by helper scripts.
GITHUB_USER_HOME="your-personal-github-user"
GITHUB_EMAIL_HOME="your-personal-github-email"
GITHUB_USER_WORK="your-work-github-user-or-org"
GITHUB_EMAIL_WORK="your-work-github-email-or-org"

# GitHub token used by mise/gh-backed installers to avoid API rate limits.
# Usually this is the variable mise expects for GitHub release downloads.
GITHUB_TOKEN="ghp_or_github_pat_here"

# Optional path to win32yank.exe when running under WSL.
WIN32YANK=""
