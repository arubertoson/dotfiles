#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")"
EMAIL="${1:-}"
PROFILE="${2:-home}"

case "$PROFILE" in
  ""|home|personal) PROFILE=home ;;
  work) ;;
  *)
    echo "usage: $0 [email] [home|work]" >&2
    exit 2
    ;;
esac

# shellcheck disable=SC1091
source "$REPO_ROOT/lib/github.sh"
# shellcheck disable=SC1091
source "$REPO_ROOT/lib/ssh.sh"

github-auth-interactive
setup-github-ssh "$EMAIL" "$PROFILE"
