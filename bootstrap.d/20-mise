#!/usr/bin/env bash
set -euo pipefail

have() { command -v "$1" >/dev/null 2>&1; }

if ! have mise; then
  curl -fsSL https://mise.jdx.dev/install.sh | sh
  export PATH="$HOME/.local/bin:$PATH"
fi

have mise || {
  echo "[20-mise] FAIL mise was not installed" >&2
  exit 1
}

echo "[20-mise] OK (mise installed; configuration is managed by 35-dotfiles)"
