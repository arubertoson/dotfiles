#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")"
UPGRADE=0

if [ "${1:-}" = --upgrade ]; then
  UPGRADE=1
elif [ $# -gt 0 ]; then
  echo "usage: $0 [--upgrade]" >&2
  exit 2
fi

if ! command -v mise >/dev/null 2>&1; then
  echo "[30-cli] mise not found. Did 20-mise run?" >&2
  exit 1
fi

# shellcheck disable=SC1091
source "$REPO_ROOT/lib/github.sh"
github-auth-required

MISE_CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/mise/config.toml"
[ -f "$MISE_CONFIG_FILE" ] || {
  echo "[30-cli] mise config not found: $MISE_CONFIG_FILE" >&2
  exit 1
}

export MISE_JOBS="${MISE_JOBS:-4}"
mise trust "$MISE_CONFIG_FILE" >/dev/null

if [ "$UPGRADE" = 1 ]; then
  mise upgrade -C "$HOME" -y
fi

mise install -C "$HOME" -y

if mise which -C "$HOME" corepack >/dev/null 2>&1; then
  mise exec -C "$HOME" -- corepack disable
fi

echo "[30-cli] OK (mise tools reconciled)"
