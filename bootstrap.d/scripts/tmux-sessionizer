#!/usr/bin/env zsh

# 1. Define your dev root
DEV_ROOT="${XDG_DEV_HOME:-$HOME/dev}"

# 2. Get the list of projects (same logic as your function)
list=$(fd -L -HI -t d '^\.git$' --base-directory "$DEV_ROOT" 2>/dev/null | sd '/\.git/$' '')

# 3. Use fzf to pick the project
dir=$(echo "$list" | fzf --ansi --no-hscroll --height=100% --layout=reverse --border)

if [ -z "$dir" ]; then
    exit 0
fi

session_name=$(basename "$dir" | tr . _)

# 4. Infrastructure Logic (The "4 Zones" we built)
if ! tmux has-session -t="$session_name" 2> /dev/null; then
    tmux new-session -ds "$session_name" -n "code" -c "$DEV_ROOT/$dir"
    tmux new-window -t "$session_name:2" -n "server" -c "$DEV_ROOT/$dir"
    tmux new-window -t "$session_name:3" -n "logs" -c "$DEV_ROOT/$dir"
    tmux new-window -t "$session_name:4" -n "misc" -c "$DEV_ROOT/$dir"
fi

# 5. Switch to the session
tmux switch-client -t "$session_name"
