#!/usr/bin/env bash
# bootstrap.d/00-zsh

set -euo pipefail

REPO_ROOT="$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")"
ZSHENV_SOURCE="${REPO_ROOT}/.zshenv"
ZSHENV_TARGET="${HOME}/.zshenv"
ZSHRC_SOURCE="${REPO_ROOT}/.zshrc"
ZDOTDIR_TARGET="${XDG_CONFIG_HOME:-$HOME/.config}/zsh"
DOTFILES_REPLACE_DIRS="${DOTFILES_REPLACE_DIRS:-0}"

# shellcheck disable=SC1091
source "$REPO_ROOT/lib/detect.sh"

[ -f "$ZSHENV_SOURCE" ] || { echo "[FAIL] ${ZSHENV_SOURCE} not found"; exit 1; }
[ -f "$ZSHRC_SOURCE" ] || { echo "[FAIL] ${ZSHRC_SOURCE} not found"; exit 1; }

backup-target() {
  local target="$1"
  local backup

  backup="$target.backup.$(date +%Y%m%d%H%M%S)"
  echo "[00-zsh] Backing up existing $target to $backup"
  mv -- "$target" "$backup"
}

link-zdot-entry() {
  local source="$1"
  local target="$2"

  if [ -L "$target" ] && [ "$(readlink -f "$target")" = "$(realpath "$source")" ]; then
    return
  fi

  if [ -e "$target" ] && [ ! -L "$target" ] && [ "$DOTFILES_REPLACE_DIRS" != 1 ]; then
    echo "[00-zsh] WARN skipping $target; set DOTFILES_REPLACE_DIRS=1 to replace it" >&2
    return
  fi

  if [ -e "$target" ] && [ ! -L "$target" ]; then
    backup-target "$target"
  fi

  ln -sfnT -- "$source" "$target"
}

if ! command -v zsh >/dev/null 2>&1 && [ "${DOT_SKIP_PACKAGES:-0}" != 1 ]; then
  case "$DOT_PACKAGE_MANAGER" in
    paru) paru -S --needed --noconfirm zsh ;;
    pacman) sudo pacman -S --needed --noconfirm zsh ;;
    apt)
      sudo apt-get update -y
      sudo apt-get install -y zsh
      ;;
    *) echo "[00-zsh] Unknown package manager: $DOT_PACKAGE_MANAGER" >&2; exit 1 ;;
  esac
fi

ZSH_PATH="$(command -v zsh || true)"
[ -n "$ZSH_PATH" ] || { echo "[FAIL] zsh not found after install"; exit 1; }

ln -sfn -- "$ZSHENV_SOURCE" "$ZSHENV_TARGET"
mkdir -p "$ZDOTDIR_TARGET"
link-zdot-entry "$ZSHRC_SOURCE" "$ZDOTDIR_TARGET/.zshrc"
link-zdot-entry "$REPO_ROOT/rc.d" "$ZDOTDIR_TARGET/rc.d"
link-zdot-entry "$REPO_ROOT/functions" "$ZDOTDIR_TARGET/functions"

if [ -r /etc/shells ] && ! grep -qx "$ZSH_PATH" /etc/shells; then
  echo "$ZSH_PATH" | sudo tee -a /etc/shells >/dev/null
fi

if command -v chsh >/dev/null 2>&1; then
  current_shell="$(getent passwd "${SUDO_USER:-$USER}" 2>/dev/null | awk -F: '{print $NF}')"

  if [ "$current_shell" != "$ZSH_PATH" ]; then
    if ! sudo chsh -s "$ZSH_PATH" "${SUDO_USER:-$USER}"; then
      if [ "${DOT_WSL:-0}" = 1 ]; then
        echo "[00-zsh] WARN chsh failed under WSL. Set the default shell manually: chsh -s $ZSH_PATH" >&2
      else
        echo "[00-zsh] FAIL chsh failed. Could not set default shell to $ZSH_PATH" >&2
        exit 1
      fi
    fi
  fi

  new_shell="$(getent passwd "${SUDO_USER:-$USER}" 2>/dev/null | awk -F: '{print $NF}')"
  if [ "${DOT_WSL:-0}" != 1 ] && [ -n "$new_shell" ] && [ "$new_shell" != "$ZSH_PATH" ]; then
    echo "[00-zsh] FAIL default shell is still $new_shell, expected $ZSH_PATH" >&2
    exit 1
  fi
else
  echo "[00-zsh] WARN chsh not found; default shell was not changed" >&2
fi

echo "[00-zsh] OK zsh bootstrapped. Start a new terminal or: exec $ZSH_PATH -l"
