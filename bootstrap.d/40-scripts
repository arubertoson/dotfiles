#!/usr/bin/env bash
set -euo pipefail

ROOT="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
SCRIPT_DIR="$(realpath "$ROOT/../scripts")"
XDG_BIN_HOME="${XDG_BIN_HOME:-$HOME/.local/bin}"

log() { printf "\033[1;36m[40-scripts]\033[0m %s\n" "$*"; }

mkdir -p "$XDG_BIN_HOME"

log "Linking scripts to $XDG_BIN_HOME"
linked_count=0
skipped_count=0
removed_count=0

for script in "$SCRIPT_DIR"/*; do
    [ -f "$script" ] || continue
    script_name=$(basename "$script")
    target="$XDG_BIN_HOME/$script_name"

    if [ -L "$target" ] && [ "$(readlink "$target")" = "$script" ]; then
        log "Script $script_name already linked correctly"
        skipped_count=$((skipped_count + 1))
    else
        log "Linking $script_name"
        ln -sfn -- "$(realpath "$script")" "$target"
        linked_count=$((linked_count + 1))
    fi
done

for target in "$XDG_BIN_HOME"/*; do
    [ -L "$target" ] || continue
    source=$(readlink "$target")

    case "$source" in
        "$SCRIPT_DIR"/*)
            [ -e "$target" ] && continue
            log "Removing obsolete managed script $(basename "$target")"
            rm -- "$target"
            removed_count=$((removed_count + 1))
            ;;
    esac
done

log "[40-scripts] OK - Linked: $linked_count, Skipped: $skipped_count, Removed: $removed_count"

exit 0

