#!/usr/bin/env bash
set -euo pipefail

ROOT="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
REPO_ROOT="$(dirname "$ROOT")"
DOTFILES="$REPO_ROOT/dotfiles"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DOTFILES_REPLACE_DIRS="${DOTFILES_REPLACE_DIRS:-0}"
COMPONENT="${1:-}"

# shellcheck disable=SC1091
source "$REPO_ROOT/lib/detect.sh"

log() { printf "\033[1;36m[35-dotfiles]\033[0m %s\n" "$*"; }

should-link-dotfile() {
  local name="$1"

  if [ -n "$COMPONENT" ] && [ "$name" != "$COMPONENT" ]; then
    return 1
  fi

  case "$name" in
    ghostty|niri|noctalia|rofi|environment.d)
      [ "$DOT_PROFILE" = arch-desktop ]
      return
      ;;
  esac

  return 0
}

link-path() {
  local source="$1"
  local target="$2"
  local name="$3"
  local backup

  if [ -L "$target" ] && [ "$(readlink -f "$target")" = "$(realpath "$source")" ]; then
    log "$name already linked correctly"
    skipped_count=$((skipped_count + 1))
    return
  fi

  if [ -e "$target" ] && [ ! -L "$target" ] && [ "$DOTFILES_REPLACE_DIRS" != 1 ]; then
    log "Skipping $name; target already exists: $target"
    log "Set DOTFILES_REPLACE_DIRS=1 to back it up and link the repo version"
    skipped_count=$((skipped_count + 1))
    return
  fi

  if [ -e "$target" ] && [ ! -L "$target" ]; then
    backup="$target.backup.$(date +%Y%m%d%H%M%S)"
    log "Backing up existing $name to $backup"
    mv -- "$target" "$backup"
  fi

  log "Linking $name"
  mkdir -p "$(dirname "$target")"
  ln -sfnT -- "$(realpath "$source")" "$target"
  linked_count=$((linked_count + 1))
}

migrate-legacy-layout() {
  local source="$1"
  local target="$2"
  local name="$3"
  local managed=0
  local backup

  if [ ! -d "$target" ] || [ -L "$target" ]; then
    return 0
  fi

  case "$name" in
    mise)
      [ -L "$target/config.toml" ] && \
        [ "$(readlink -f "$target/config.toml")" = "$(realpath "$source/config.toml")" ] && managed=1
      ;;
    zsh)
      [ -L "$target/.zshrc" ] && \
        [ "$(readlink "$target/.zshrc")" = "$REPO_ROOT/.zshrc" ] && managed=1
      ;;
  esac

  [ "$managed" = 1 ] || return 0
  backup="$target.backup.$(date +%Y%m%d%H%M%S)"
  log "Migrating legacy managed $name directory to $backup"
  mv -- "$target" "$backup"
}

link-dotfile() {
  local dot="$1"
  local name
  local target

  name="$(basename "$dot")"
  if ! should-link-dotfile "$name"; then
    return
  fi

  target="$XDG_CONFIG_HOME/$name"
  if [ "$name" = ".tmux.conf" ]; then
    target="$HOME/$name"
  fi

  migrate-legacy-layout "$dot" "$target" "$name"
  link-path "$dot" "$target" "$name"
  if [ "$name" = zsh ]; then
    link-path "$dot/.zshenv" "$HOME/.zshenv" ".zshenv"
  fi
}

if [ -n "$COMPONENT" ] && [ ! -e "$DOTFILES/$COMPONENT" ]; then
  echo "[35-dotfiles] Unknown component: $COMPONENT" >&2
  exit 1
fi

mkdir -p "$XDG_CONFIG_HOME"
log "Linking ${COMPONENT:-all dotfiles} for $DOT_PROFILE"
linked_count=0
skipped_count=0
removed_count=0

shopt -s nullglob dotglob
for dot in "$DOTFILES"/*; do
  [ -f "$dot" ] || [ -d "$dot" ] || continue
  link-dotfile "$dot"
done

if [ -z "$COMPONENT" ]; then
  for target in "$XDG_CONFIG_HOME"/*; do
    [ -L "$target" ] || continue
    source=$(readlink "$target")

    case "$source" in
      "$DOTFILES"/*)
        [ -e "$target" ] && continue
        log "Removing obsolete managed dotfile $(basename "$target")"
        rm -- "$target"
        removed_count=$((removed_count + 1))
        ;;
    esac
  done
fi

log "OK - Linked: $linked_count, Skipped: $skipped_count, Removed: $removed_count"
