#!/usr/bin/env bash
set -euo pipefail

ROOT="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
REPO_ROOT="$(dirname "$ROOT")"
DOTFILES="$REPO_ROOT/dotfiles"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
DOTFILES_REPLACE_DIRS="${DOTFILES_REPLACE_DIRS:-0}"

# shellcheck disable=SC1091
source "$REPO_ROOT/lib/detect.sh"

log() { printf "\033[1;36m[35-dotfiles]\033[0m %s\n" "$*"; }

should-link-dotfile() {
  local name="$1"

  case "$name" in
    ghostty|niri|noctalia|rofi|environment.d)
      [ "$DOT_PROFILE" = arch-desktop ]
      return
      ;;
  esac

  return 0
}

link-dotfile() {
  local dot="$1"
  local name
  local source
  local target
  local backup

  name="$(basename "$dot")"
  source="$(realpath "$dot")"

  if ! should-link-dotfile "$name"; then
    log "Skipping $name for profile $DOT_PROFILE"
    skipped_count=$((skipped_count + 1))
    return
  fi

  target="$XDG_CONFIG_HOME/$name"
  if [ "$name" = ".tmux.conf" ]; then
    target="$HOME/$name"
  fi

  if [ -L "$target" ] && [ "$(readlink "$target")" = "$source" ]; then
    log "dot $name already linked correctly"
    skipped_count=$((skipped_count + 1))
    return
  fi

  if [ -d "$target" ] && [ ! -L "$target" ] && [ "$DOTFILES_REPLACE_DIRS" != 1 ]; then
    log "Skipping $name; target directory already exists: $target"
    log "Set DOTFILES_REPLACE_DIRS=1 to back it up and link the repo version"
    skipped_count=$((skipped_count + 1))
    return
  fi

  if [ -d "$target" ] && [ ! -L "$target" ]; then
    backup="$target.backup.$(date +%Y%m%d%H%M%S)"
    log "Backing up existing $name to $backup"
    mv -- "$target" "$backup"
  fi

  log "Linking $name"
  ln -sfnT -- "$source" "$target"
  linked_count=$((linked_count + 1))
}

mkdir -p "$XDG_CONFIG_HOME"

log "Linking dotfiles to $XDG_CONFIG_HOME for $DOT_PROFILE"
linked_count=0
skipped_count=0

shopt -s nullglob dotglob

for dot in "$DOTFILES"/*; do
  [ -f "$dot" ] || [ -d "$dot" ] || continue
  link-dotfile "$dot"
done

find "$XDG_CONFIG_HOME" -type l ! -exec test -e {} \; -delete 2>/dev/null || true

log "[35-dotfiles] OK - Linked: $linked_count, Skipped: $skipped_count"
