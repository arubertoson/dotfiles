#!/usr/bin/env bash
set -euo pipefail

DEST="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions"
CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
MISE_SHIMS="${MISE_SHIMS:-$HOME/.local/share/mise/shims}"

if [ -d "$MISE_SHIMS" ] && [[ ":$PATH:" != *":$MISE_SHIMS:"* ]]; then
  export PATH="$MISE_SHIMS:$PATH"
fi

generate-completion() {
  local name="$1"
  shift

  command -v "$1" >/dev/null 2>&1 || return 0

  local target="$DEST/$name"
  local tmp="$target.$$"

  if "$@" > "$tmp" && [ -s "$tmp" ]; then
    chmod 644 "$tmp"
    mv -- "$tmp" "$target"
    printf '[32-completions] Generated %s\n' "$name"
    return
  fi

  rm -f -- "$tmp"
  printf '[32-completions] Failed to generate %s\n' "$name" >&2
  return 1
}

mkdir -p "$DEST"

generate-completion _mise mise completion zsh
generate-completion _just just --completions zsh
generate-completion _gh gh completion -s zsh
generate-completion _jj jj util completion zsh
generate-completion _niri niri completions zsh

# Znap rebuilds this index on the next interactive shell. Removing only its own
# cache ensures newly generated and repository-owned functions are discovered.
rm -f -- "$CACHE/compdump" "$CACHE/compdump.zwc"

echo "[32-completions] OK"
