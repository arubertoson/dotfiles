#!/usr/bin/env bash
set -euo pipefail

ROOT="$(dirname "$(realpath "$BASH_SOURCE")")"
DEV_DIR="${DOTFILES_REPO_DIR:-${XDG_DEV_HOME:-$HOME/dev}/home/github.com/arubertoson/zsh}"

log() { printf "\033[1;36m[BOOT]\033[0m %s\n" "$*"; }
error() { printf "\033[1;31m[ERROR]\033[0m %s\n" "$*"; }

adopt-repo-location() {
  local root_real
  local dev_real

  root_real="$(realpath -m "$ROOT")"
  dev_real="$(realpath -m "$DEV_DIR")"

  [ "${DOTFILES_ADOPT_REPO:-1}" = 1 ] || return 0
  [ "$root_real" != "$dev_real" ] || return 0

  if [ -L "$DEV_DIR" ] && [ "$(readlink -f "$DEV_DIR")" = "$root_real" ]; then
    log "Removing old canonical symlink: $DEV_DIR"
    rm -- "$DEV_DIR"
  fi

  if [ -e "$DEV_DIR" ]; then
    error "Canonical repo path already exists: $DEV_DIR"
    error "Run bootstrap from that checkout, remove it, or set DOTFILES_ADOPT_REPO=0."
    exit 1
  fi

  log "Moving repo into canonical location"
  log "  from: $ROOT"
  log "  to:   $DEV_DIR"
  mkdir -p "$(dirname "$DEV_DIR")"
  mv -- "$ROOT" "$DEV_DIR"
  cd "$DEV_DIR"
  exec "$DEV_DIR/bootstrap" "$@"
}

adopt-repo-location "$@"

ROOT="$(dirname "$(realpath "$BASH_SOURCE")")"
STAGES_DIR="$ROOT/bootstrap.d"

# shellcheck disable=SC1091
source "$ROOT/lib/detect.sh"

log "Detected profile"
_dot_detect_log | sed 's/^/[BOOT]   /'

case "$DOT_PROFILE" in
  arch|arch-desktop|wsl-ubuntu) ;;
  *)
    error "Unsupported profile: $DOT_PROFILE"
    error "Set DOT_PROFILE to arch, arch-desktop, or wsl-ubuntu."
    exit 1
    ;;
esac

run-stage() {
  local name="$1"
  shift

  log "Running $name"
  if "$STAGES_DIR/$name" "$@"; then
    log "Stage $name completed successfully"
    return
  fi

  error "Stage $name failed"
  exit 1
}

# Bootstrap composes required setup explicitly. Optional components such as SSH
# and Neovim have dedicated commands and do not run merely because a stage exists.
run-stage 10-dev
run-stage 20-mise
run-stage 35-dotfiles mise
run-stage 25-github-auth
run-stage 30-cli
run-stage 32-completions
run-stage 35-dotfiles
run-stage 40-scripts
run-stage 00-zsh

log "Repo location: $ROOT"

if command -v just >/dev/null 2>&1; then
  log "All stages complete. Run 'just status' to check current state."
else
  log "All stages complete. Start a new shell, then run 'just status' once mise shims are active."
fi
