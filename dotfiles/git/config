[includeIf "gitdir:~/dev/home/"]
    path = ~/.config/git/home

[includeIf "gitdir:~dev/work/"]
    path = ~/.config/git/work

[core]
    pager = delta
    editor = nvim

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # Use n/N to jump between diff sections
    light = false      # Set to true if using a light terminal theme
    side-by-side = true  # Enable side-by-side diffs
    line-numbers = true  # Show line numbers
    syntax-theme = Dracula  # Matches Neovim's aesthetic; adjust as needed

[merge]
    conflictstyle = diff3

[diff]
  tool = nvim_difftool

[difftool "nvim_difftool"]
  cmd = nvim -c \"packadd nvim.difftool\" -c \"DiffTool $LOCAL $REMOTE\"

[alias]
    st = status --short --branch
    co = checkout
    br = branch
    ci = commit
    cm = commit -m
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    amend = commit --amend --no-edit
    unstage = reset HEAD --
    fixup = commit --fixup
    rebase-i = rebase -i
    pushf = push --force-with-lease
[color "status"]
	branch = 12 normal
	added = 10 normal
	updated = 10 normal
	localbranch = 12 normal
	changed = 11 normal
	header = normal
	remotebranch = 6 normal
	nobranch = 1 normal
	unmerged = 9 normal
	untracked = 8 normal
[color "branch"]
	plain = normal
	remote = 6 normal
	current = 15 4
	local = 12 normal
	upstream = 6 normal
[color "remote"]
	hint = 8 normal
	success = 10 normal
	error = 9 normal
	warning = 11 normal
[color "interactive"]
	header = 8 normal bold
	prompt = 15 4
	help = 8 normal
	error = 9 normal
[color "diff"]
	commit = 3 normal
	newMoved = 15 5
	oldMovedAlternativeDimmed = 15 8 dim
	frag = 8 normal
	oldMovedAlternative = 15 8
	contextBold = normal bold
	newBold = 15 2 bold
	context = normal
	contextDimmed = normal dim
	oldMoved = 15 3
	oldBold = 15 1 bold
	newMovedDimmed = 15 5 dim
	func = 8 normal
	meta = 8 normal
	newDimmed = 15 2 dim
	newMovedAlternative = 15 4
	new = 15 2
	newMovedAlternativeDimmed = 15 4 dim
	whitespace = normal 9
	oldMovedDimmed = 15 3 dim
	oldDimmed = 15 1 dim
	old = 15 1
[color "decorate"]
	branch = 12 normal
	tag = 5 normal
	remotebranch = 6 normal
	stash = 3 normal
	grafted = 1 normal
	HEAD = 7 4
[init]
	defaultBranch = main
