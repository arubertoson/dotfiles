#!/bin/zsh
# pi quick-question helpers
#
# q  = one-off, no saved session
# qq = saved session, for follow-up with qc
# qc = continue previous saved quick-question session

: "${PI_Q_PROVIDER:=openai-codex}"
: "${PI_Q_MODEL:=gpt-5.4-mini}"
: "${PI_Q_THINKING:=off}"
: "${PI_Q_SYSTEM:=Answer concisely, prefer clarity over cleverness and sacrifice grammar for concision.}"
: "${PI_Q_SESSION_NAME:=quick question}"

unalias q qq qc 2>/dev/null

_pi-q-die() {
  printf '%s\n' "pi-q: $*" >&2
  return 1
}

_pi-q-has-stdin() {
  [ ! -t 0 ]
}

_pi-q-run() {
  local mode="$1"
  shift

  local input=""
  local -a prompt=( "$@" )
  local -a session=()

  if _pi-q-has-stdin; then
    input="$(cat)"
  fi

  if [ -n "$input" ] && [ "${#prompt[@]}" -gt 0 ]; then
    prompt=( "$input" "${prompt[@]}" )
  elif [ -n "$input" ]; then
    prompt=( "$input" )
  fi

  [ "${#prompt[@]}" -eq 0 ] && _pi-q-die "no input provided" && return 1

  case "$mode" in
    once) session=( --no-session ) ;;
    new) session=( --name "$PI_Q_SESSION_NAME" ) ;;
    continue) session=( --continue ) ;;
    *) _pi-q-die "unknown mode '$mode'"; return 1 ;;
  esac

  command pi \
    --provider "$PI_Q_PROVIDER" \
    --model "$PI_Q_MODEL" \
    --thinking "$PI_Q_THINKING" \
    --system-prompt "$PI_Q_SYSTEM" \
    --no-tools \
    -p \
    "${session[@]}" \
    "${prompt[@]}"
}

q() {
  _pi-q-run once "$@"
}

qq() {
  _pi-q-run new "$@"
}

qc() {
  _pi-q-run continue "$@"
}
